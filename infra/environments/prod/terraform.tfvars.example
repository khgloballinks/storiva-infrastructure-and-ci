aws_region     = "eu-north-1"
key_name       = "storiva-prod-key"
s3_bucket_name = "storiva-prod-storage"
db_name        = "storiva_prod"
db_username    = "storiva_prod_user"

# SENSITIVE — pass via environment variables:
# export TF_VAR_db_password="..."
# export TF_VAR_cloudflare_api_token="..."
# export TF_VAR_cloudflare_zone_id="..."
# export TF_VAR_ssh_allowed_cidr="YOUR.IP/32"
